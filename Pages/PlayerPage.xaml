<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NuLigaViewer.Pages.PlayerPage"
             Title="{Binding Spieler}">

    <Grid Padding="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="12" Padding="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center">
                <Label Text="Alte DWZ" FontSize="12" HorizontalTextAlignment="Center" Opacity="0.8" />
                <Label Text="{Binding DWZ}" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                <Label Text="Niveau" FontSize="12" HorizontalTextAlignment="Center" Opacity="0.8" />
                <Label Text="{Binding AverageOpponentDWZ}" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center">
                <Label Text="Leistung" FontSize="12" HorizontalTextAlignment="Center" Opacity="0.8" />
                <Label Text="{Binding Performance}" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3" Spacing="2" HorizontalOptions="Center">
                <Label Text="Neue DWZ" FontSize="12" HorizontalTextAlignment="Center" Opacity="0.8" />
                <Label Text="{Binding EstimatedNewDwzString}" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="1" Padding="6" VerticalOptions="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="45" />
                <ColumnDefinition Width="35" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" Text="Runde" FontAttributes="Bold" VerticalTextAlignment="Center" />
            <Label Grid.Column="1" Text="Brett" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
            <Label Grid.Column="2" Text="Gegner" FontAttributes="Bold" VerticalTextAlignment="Center" />
            <Label Grid.Column="3" Text="DWZ" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
            <Label Grid.Column="4" Text="Ergebnis" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
            <Label Grid.Column="5" Text="Verein" FontAttributes="Bold" VerticalTextAlignment="Center" />
        </Grid>

        <CollectionView Grid.Row="2" ItemsSource="{Binding PlayerGameDayInfos}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="2" Padding="6">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Grid ColumnSpacing="1" VerticalOptions="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="35" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Label Grid.Column="0" Grid.Row="0" Text="{Binding Pairing.RelatedGameDay.Runde}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Grid.Row="0" Text="{Binding Pairing.Brett}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Grid.Row="0" Text="{Binding Opponent}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="3" Grid.Row="0" Text="{Binding OpponentDWZString}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="4" Grid.Row="0" Text="{Binding ResultForPlayer}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="5" Grid.Row="0" Text="{Binding OpponentTeam}" VerticalTextAlignment="Center" />

                            <Label Grid.Column="0" Grid.Row="1" IsVisible="{Binding SecExists}" Text="{Binding SecondPairing.RelatedGameDay.Runde}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Grid.Row="1" IsVisible="{Binding SecExists}" Text="{Binding SecondPairing.Brett}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Grid.Row="1" IsVisible="{Binding SecExists}" Text="{Binding SecOpponent}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="3" Grid.Row="1" IsVisible="{Binding SecExists}" Text="{Binding SecOpponentDWZString}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="4" Grid.Row="1" IsVisible="{Binding SecExists}" Text="{Binding SecResultForPlayer}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="5" Grid.Row="1" IsVisible="{Binding SecExists}" Text="{Binding SecOpponentTeam}" VerticalTextAlignment="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>