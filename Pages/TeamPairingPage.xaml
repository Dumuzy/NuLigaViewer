<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NuLigaViewer.Pages.TeamPairingPage"
             Title="{Binding Title}">

    <Grid Padding="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="1" Padding="6" VerticalOptions="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" Text="Brett" FontAttributes="Bold" VerticalTextAlignment="Center" />
            <Label Grid.Column="1" Text="{Binding HeimMannschaft}" FontAttributes="Bold" VerticalTextAlignment="Center" />
            <Label Grid.Column="2" Text="DWZ" FontAttributes="Bold" VerticalTextAlignment="Center" />
            <Label Grid.Column="3" Text="{Binding GastMannschaft}" FontAttributes="Bold" VerticalTextAlignment="Center" />
            <Label Grid.Column="4" Text="DWZ" FontAttributes="Bold" VerticalTextAlignment="Center" />
            <Label Grid.Column="5" Text="Erg." FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
        </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Report.Pairings}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="2" Padding="6">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Grid ColumnSpacing="1" VerticalOptions="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" Text="{Binding Brett}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding HeimSpieler}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding VisibleHomeDWZ}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="3" Text="{Binding GastSpieler}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="4" Text="{Binding VisibleGuestDWZ}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="5" Text="{Binding Ergebnis}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>