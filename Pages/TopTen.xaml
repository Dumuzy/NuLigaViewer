<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NuLigaViewer.Pages.TopTen"
             Title="{Binding League.Name}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Zurück zur Übersicht"
                     Priority="0"
                     Order="Primary"
                     Clicked="OnBackButtonClicked" />
    </ContentPage.ToolbarItems>

    <Grid Padding="8">
        <Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <HorizontalStackLayout Grid.Row="0" VerticalOptions="Center">
            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" VerticalOptions="Center" />
        </HorizontalStackLayout>

		<Grid Grid.Row="1" ColumnSpacing="1" Padding="6" BackgroundColor="{DynamicResource PageBackgroundColor}">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="35" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="50" />
            </Grid.ColumnDefinitions>

			<Label Grid.Column="0" Text="Rang" FontAttributes="Bold" VerticalTextAlignment="Center" />
			<Label Grid.Column="1" Text="Spieler" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
			<Label Grid.Column="2" Text="DWZ" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
			<Label Grid.Column="3" Text="Verein" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
			<Label Grid.Column="4" Text="Punkte" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
			<Label Grid.Column="5" Text="Spiele" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
		</Grid>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding TopTenPlayer}"
                        SelectionMode="Single"
                        SelectionChanged="OnTeamSelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="2" Padding="6">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>

                        <Grid ColumnSpacing="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="35" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="50" />
                            </Grid.ColumnDefinitions>

							<Label Grid.Column="0" Text="{Binding Rang}" VerticalTextAlignment="Center" />
							<Label Grid.Column="1" Text="{Binding Name}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding DWZ}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
							<Label Grid.Column="3" Text="{Binding Verein}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
							<Label Grid.Column="4" Text="{Binding Punkte}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
							<Label Grid.Column="5" Text="{Binding Spiele}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>