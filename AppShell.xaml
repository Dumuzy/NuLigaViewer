<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="NuLigaViewer.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:NuLigaViewer"
    xmlns:pages="using:NuLigaViewer.Pages"
    Title="NuLigaViewer"
    FlyoutBehavior="Disabled">

    <ShellContent
            Title="Verbandsrunde 2025/26"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="home">
    </ShellContent>
    <TabBar Route="league">
        <ShellContent Title="Tabelle"
                          ContentTemplate="{DataTemplate pages:LeaguePage}"
                          Route="table" />
        <ShellContent Title="Letzter Spieltag"
                          ContentTemplate="{DataTemplate pages:GameDayPage}"
                          Route="lastgameday" />
        <ShellContent Title="Top 10"
                          ContentTemplate="{DataTemplate pages:TopTenPage}"
                          Route="topten" />
    </TabBar>
</Shell>
