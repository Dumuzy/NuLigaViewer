<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="NuLigaViewer.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:NuLigaViewer"
    xmlns:pages="using:NuLigaViewer.Pages"
    Title="NuLigaViewer">

    <ShellContent
        Title="Verbandsrunde 2025/26"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <TabBar>
        <ShellContent Title="Tabelle"
                          ContentTemplate="{DataTemplate pages:TeamsPage}"
                          Route="Teams.Table" />

        <ShellContent Title="Spieltag"
                          ContentTemplate="{DataTemplate pages:TeamsGameDay}"
                          Route="Teams.GameDay" />
    </TabBar>
</Shell>
