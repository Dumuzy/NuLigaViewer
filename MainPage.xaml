<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NuLigaViewer.MainPage">

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <CollectionView Grid.Column="0"
                        ItemsSource="{Binding Leagues}"
                        SelectedItem="{Binding SelectedLeague, Mode=TwoWay}"
                        SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Label Text="{Binding Name}"/>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <HorizontalStackLayout Grid.Column="0">
                    <Label Text="{Binding SelectedLeague.Name}" FontSize="16" FontFamily="SemiBold" VerticalTextAlignment="Center"/>
                    <Label Text="  " />
                    <Label Text="(loading...)" IsVisible="{Binding IsLoading}" VerticalTextAlignment="Center"/>
                </HorizontalStackLayout>

                <Button Grid.Column="1"
                        Text="Zuklappen"
                        Margin="8,0,0,0"
                        VerticalOptions="Center"
                        ToolTipProperties.Text="Klappt Spieler oder Spielpaarungen zusammen"
                        Command="{Binding CollapseSelectionsCommand}" />
            </Grid>

            <CollectionView Grid.Row="1"
                  ItemsSource="{Binding Teams}"
                  SelectedItem="{Binding SelectedTeamView, Mode=TwoWay}"
                  SelectionMode="Single">
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
