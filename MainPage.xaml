<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NuLigaViewer.MainPage"
             Title="Verbandsliga Baden und Karlsruhe">

    <CollectionView ItemsSource="{Binding Leagues}"
                    SelectionMode="Single"
                    SelectionChanged="OnLeagueSelected">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Margin="6" Padding="6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold" />
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>

        <CollectionView.EmptyView>
            <Label Text="No leagues available" HorizontalOptions="Center" VerticalOptions="Center" />
        </CollectionView.EmptyView>
    </CollectionView>
</ContentPage>
